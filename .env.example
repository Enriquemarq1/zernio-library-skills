# Zernio API credentials
# ----------------------
# Copy this file to .env and fill in your real key:
#
#   cp .env.example .env
#   # then edit .env and replace the placeholder
#
# .env is gitignored — never commit it.
# Get your key from https://zernio.com/dashboard/api-keys
#
# Used by scripts/post.sh (auto-sourced if present).
# Claude Code CLI users can also `export ZERNIO_API_KEY=...` directly
# instead of using this file.
# Claude.ai web users don't need this file at all — paste the key in chat
# at the start of the conversation.

ZERNIO_API_KEY=zk_replace_with_your_real_key
