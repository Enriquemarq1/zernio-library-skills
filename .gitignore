# Local post logs
posts/
*.log

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Secrets (never commit)
# Note: .env IS tracked here (ships with a placeholder). After cloning,
# run `git update-index --skip-worktree .env` so your local edits with
# the real key don't get staged. See the header comment in .env.
.env.local
.env.keys
*.pem
*.key

# Manifest staging (creators may stage drafts here)
drafts/

# Node / Python by-products (in case anyone scripts around this repo)
node_modules/
__pycache__/
*.pyc
