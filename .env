# Zernio API credentials
# ----------------------
#
# WARNING — DO NOT COMMIT YOUR REAL KEY
# This file ships with a placeholder. When you replace the placeholder
# with your real Zernio API key, your local copy will become sensitive
# but the file is NOT gitignored. To prevent yourself from accidentally
# committing your real key, run this once after cloning:
#
#   git update-index --skip-worktree .env
#
# That tells Git to ignore your local changes to this file without
# untracking it. You can later un-skip with:
#
#   git update-index --no-skip-worktree .env
#
# Get your key from https://zernio.com/dashboard/api-keys
# Used by scripts/post.sh (auto-sourced if present).
# Claude Code CLI users: this file or `export ZERNIO_API_KEY=...` both work.
# Claude.ai web users: don't need this file — paste the key in chat at the
# start of the conversation.

ZERNIO_API_KEY=zk_replace_with_your_real_key
